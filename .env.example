# DATABASE_URL is used by the app runtime through the Supabase transaction-mode pooler.
# DIRECT_URL is used by Prisma migrations/db push through the Supabase session/direct pooler.
# Never commit real .env values.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_SUPABASE_DB_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_SUPABASE_DB_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
GROQ_API_KEY=""

PAYMENT_PROVIDER="dodo"
PAYMENTS_ENABLED="true"
DODO_ENVIRONMENT="test"
DODO_API_KEY=""
DODO_PRODUCT_ID="pdt_0Nht94BX3XPxDSvS9qsc5"
DODO_WEBHOOK_SECRET=""

NEXT_PUBLIC_SITE_URL="https://jobresumematch.com"

